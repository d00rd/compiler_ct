
VOID ID(main) LPAREN RPAREN
LBRACE
IF LPAREN CT_INT(12) EQUAL CT_INT(12) RPAREN ID(put_s) LPAREN CT_STRING("\"equal\"\t\t(h,o)") RPAREN SEMICOLON
ELSE ID(put_s) LPAREN CT_STRING("\"not equal'\"\t\t(h,o)") RPAREN SEMICOLON
IF LPAREN CT_REAL(2.000000) MINUS CT_INT(1) EQUAL CT_REAL(2.000000) AND CT_REAL(2.000000) ID(e) PLUS CT_INT(1) EQUAL CT_INT(2) RPAREN ID(put_c) LPAREN CT_CHAR(=) RPAREN SEMICOLON
ELSE ID(put_c) LPAREN CT_CHAR(\) RPAREN SEMICOLON
RBRACE
